# ---------------------------------------------------------------------------
# Copy this file to apps/api/.env (and apps/web/.env for the VITE_ vars)
# and fill in real values. Nothing here is a secret by itself.
# ---------------------------------------------------------------------------

# --- apps/api -----------------------------------------------------------
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Supabase project (Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Supabase Postgres connection string (Settings -> Database -> Connection string, "URI")
# Used only by supabase/scripts/migrate.ts to apply migrations.
SUPABASE_DB_URL=

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# SMS provider: "console" (dev, logs OTP) or "africastalking"
SMS_PROVIDER=console
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

# --- apps/web -------------------------------------------------------------
VITE_API_URL=http://localhost:4000
