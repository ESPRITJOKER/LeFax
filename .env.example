# Lefax Course — environment variables
#
# Frontend (Vite) variables MUST be prefixed VITE_ and are safe to expose to
# the browser (anon key is designed for client use — RLS is what protects
# data, see supabase/migrations/0001_init.sql). Copy this file to .env.local
# and fill in real values once you've created a Supabase project.

# --- Frontend (Vite) --------------------------------------------------------

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Project "anon" public API key (Project Settings -> API in the Supabase dashboard)
VITE_SUPABASE_ANON_KEY=

# Set to "true" once a real SMS/OTP provider is configured (CDC 6.1 / 8).
# While false, Register.tsx uses the auth-otp Edge Function's no-SMS bypass
# (Admin API user creation with phone_confirm: true) instead of the native
# supabase.auth.signUp/verifyOtp flow, so sign-up works without SMS.
VITE_AUTH_OTP_ENABLED=false

# --- Supabase Edge Function secrets -----------------------------------------
# Set these with `supabase secrets set KEY=value` (never in a frontend .env
# file — they must never reach the browser bundle).

# Service role key (Project Settings -> API). Bypasses RLS — used only
# inside Edge Functions (supabase/functions/*), never in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key for the AI QCM-generation engine (CDC 6.8 / 8).
# Used by supabase/functions/ai-content. Paid, usage-based — not provisioned
# in this scaffold.
ANTHROPIC_API_KEY=

# Commercial SMS/OTP provider (CDC 6.1 / 8). Paid, usage-based — not
# provisioned in this scaffold. Pick one provider (e.g. "twilio") and set
# its credentials; supabase/functions/auth-otp shows the Twilio Verify
# request shape as a reference implementation.
SMS_PROVIDER=
SMS_PROVIDER_API_KEY=
# Twilio-specific (only needed if SMS_PROVIDER=twilio):
TWILIO_ACCOUNT_SID=
TWILIO_VERIFY_SERVICE_SID=

# --- Optional / future ------------------------------------------------------

# Web Push (VAPID) keys for browser push notifications (CDC 6.11). Not yet
# wired into the notifications Edge Function — generate with `npx web-push
# generate-vapid-keys` when you get to that part.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
